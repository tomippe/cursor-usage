{
  "name": "cursor-usage",
  "version": "1.0.5",
  "l10n": "./l10n",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomippe/cursor-usage"
  },
  "main": "./dist/extension.js",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cursor-usage.showDetails",
        "title": "%command.showDetails%"
      },
      {
        "command": "cursor-usage.refresh",
        "title": "%command.refresh%"
      },
      {
        "command": "cursor-usage.openDashboard",
        "title": "%command.openDashboard%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "cursorUsage.pollInterval": {
          "type": "number",
          "default": 5,
          "enum": [
            1,
            5,
            10,
            30,
            60
          ],
          "enumDescriptions": [
            "%config.pollInterval.enum.1%",
            "%config.pollInterval.enum.5%",
            "%config.pollInterval.enum.10%",
            "%config.pollInterval.enum.30%",
            "%config.pollInterval.enum.60%"
          ],
          "description": "%config.pollInterval.description%"
        },
        "cursorUsage.minimalMode": {
          "type": "boolean",
          "default": false,
          "description": "%config.minimalMode.description%"
        },
        "cursorUsage.usageDuration": {
          "type": "string",
          "default": "billingCycle",
          "enum": [
            "1d",
            "7d",
            "30d",
            "billingCycle"
          ],
          "enumItemLabels": [
            "%config.usageDuration.enum.1d%",
            "%config.usageDuration.enum.7d%",
            "%config.usageDuration.enum.30d%",
            "%config.usageDuration.enum.billingCycle%"
          ],
          "enumDescriptions": [
            "%config.usageDuration.enumDesc.1d%",
            "%config.usageDuration.enumDesc.7d%",
            "%config.usageDuration.enumDesc.30d%",
            "%config.usageDuration.enumDesc.billingCycle%"
          ],
          "description": "%config.usageDuration.description%"
        },
        "cursorUsage.modelBreakdownSortBy": {
          "type": "string",
          "default": "tokens",
          "enum": [
            "model",
            "requests",
            "tokens",
            "spend"
          ],
          "enumItemLabels": [
            "%config.modelBreakdownSortBy.enum.model%",
            "%config.modelBreakdownSortBy.enum.requests%",
            "%config.modelBreakdownSortBy.enum.tokens%",
            "%config.modelBreakdownSortBy.enum.spend%"
          ],
          "description": "%config.modelBreakdownSortBy.description%"
        },
        "cursorUsage.modelBreakdownSortOrder": {
          "type": "string",
          "default": "desc",
          "enum": [
            "asc",
            "desc"
          ],
          "enumItemLabels": [
            "%config.modelBreakdownSortOrder.enum.asc%",
            "%config.modelBreakdownSortOrder.enum.desc%"
          ],
          "description": "%config.modelBreakdownSortOrder.description%"
        },
        "cursorUsage.excludeZeroTokenModels": {
          "type": "boolean",
          "default": false,
          "description": "%config.excludeZeroTokenModels.description%"
        },
        "cursorUsage.quotaAwareEventDisplay": {
          "type": "boolean",
          "default": true,
          "description": "%config.quotaAwareEventDisplay.description%"
        }
      }
    }
  },
  "description": "%extension.description%",
  "displayName": "%extension.displayName%",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "license": "MIT",
  "publisher": "tomippe",
  "author": "tomippe",
  "scripts": {
    "build": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "package": "node esbuild.config.mjs --production && mkdir -p build && VERSION=$(node -p \"require('./package.json').version\") && npx --yes @vscode/vsce package --out \"build/cursor-usage-${VERSION}.vsix\" --baseContentUrl https://github.com/tomippe/cursor-usage/raw/main --baseImagesUrl https://github.com/tomippe/cursor-usage/raw/main",
    "package:vsm": "node esbuild.config.mjs --production && node scripts/prepare-vsm-package.mjs && VERSION=$(node -p \"require('./package.json').version\") && cd \"build/vsm-package\" && npx --yes @vscode/vsce package --out \"../cursor-usage-tomippe-${VERSION}.vsix\"",
    "publish:ovsx": "./scripts/publish-ovsx.sh",
    "publish:vsm": "npm run package:vsm && VERSION=$(node -p \"require('./package.json').version\") && npx --yes @vscode/vsce publish --packagePath \"build/cursor-usage-tomippe-${VERSION}.vsix\" -p \"$VSCE_PAT\""
  },
  "homepage": "https://apps.tomippe.jp/cursor-usage/",
  "bugs": "https://github.com/tomippe/cursor-usage/issues"
}
